# ---- Application ----
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=info
API_KEY=change-me-in-prod

# ---- Database ----
POSTGRES_DB=tssi
POSTGRES_USER=tssi
POSTGRES_PASSWORD=tssi_dev_password
POSTGRES_PORT=5432

# ---- Scraper / Proxy ----
# Full proxy URL format: http://user:pass@host:port (or leave blank to disable)
HTTP_PROXY=
HTTPS_PROXY=
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=30000

# ---- Index config ----
# Baseline = 100. The Thai Street Survival Index normalizes the composite
# PPU against this anchor day, matching the brief's "January 2020 = 100"
# five-asset specification.
TSSI_BASELINE_DATE=2020-01-01

# ---- Demo mode ----
# When true, the public site at "/" and the JSON API both render from an
# in-memory, era-aware synthetic series so you can preview everything
# without Docker / TimescaleDB. The same fake session powers both, so the
# numbers always agree.
#
# DEMO_WINDOW_DAYS controls how far back the synthetic history extends and
# where TSSI_BASELINE_DATE auto-anchors (today − DEMO_WINDOW_DAYS + 1).
# Default is 2200 (~6 years). The era model is piecewise-linear across
# five assets (Rice 25% / Mama 15% / EZYGO 35% / Water 15% / M-150 10%):
#   * pre-shock stable         (2020-01 → 2020-06,     x1.00)
#   * pandemic deflation       (2020-07 → 2021-12,     x0.97 trough)
#   * post-Ukraine inflation   (2022-01 → 2023-12,     x1.06)
#   * shrinkflation divergence (2024-01 → today,
#                               x1.09 Mama / x1.10 Water / x1.12 M-150
#                               / x1.14 EZYGO / x1.15 Rice)
DEMO_MODE=false
DEMO_WINDOW_DAYS=2200

# ---- Static mode ----
# When true, the process reads every TSSI figure from
# ``data/observations.csv`` instead of Postgres. This is the same code
# path used by ``scripts/build_static.py`` for Cloudflare Pages builds —
# enabling it locally gives you a production-parity preview on
# ``uvicorn app.main:app`` with no Docker / DB dependency.
#
# Behavior when enabled:
#   * ``get_session`` FastAPI dep is swapped for a CSV-backed shim.
#   * ``TSSI_BASELINE_DATE`` auto-anchors to the earliest row in the
#     CSV (unless you set it explicitly above).
#   * The scraper / trigger endpoint and the demo banner are both off.
#
# Mutual exclusion: if both DEMO_MODE=true and STATIC_MODE=true are set
# the demo synthetic series wins — pick one.
STATIC_MODE=false
